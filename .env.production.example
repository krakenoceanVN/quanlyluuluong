# ───────── PRODUCTION (copy thành .env.production rồi điền giá trị thật) ─────────

# Tên miền đã trỏ A record về IP công khai của ECS (KHÔNG kèm http/https)
DOMAIN=traffic.yourdomain.com
# Email nhận thông báo Let's Encrypt (nên có, để trống cũng được)
ACME_EMAIL=admin@yourdomain.com

# URL công khai dùng để render link /main/link/... (PHẢI là https + tên miền thật)
PUBLIC_LINK_DOMAIN=https://traffic.yourdomain.com

# PostgreSQL — ĐỔI mật khẩu mạnh
POSTGRES_USER=tms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=tms

# JWT — BẮT BUỘC đổi, mỗi cái là một chuỗi ngẫu nhiên dài (vd: openssl rand -hex 32)
JWT_ACCESS_SECRET=CHANGE_ME_random_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_random_refresh_secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# Tài khoản quản trị khởi tạo (seed) — ĐẶT mật khẩu mạnh
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Engine
TRAFFIC_SYNC_INTERVAL_SEC=60
LINK_CACHE_TTL_SEC=30
