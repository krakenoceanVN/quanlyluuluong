# ───────── Shared ─────────
# Public domain used to render full link URLs (no trailing slash)
PUBLIC_LINK_DOMAIN=http://localhost:3000

# ───────── API ─────────
API_PORT=3000
NODE_ENV=development

# PostgreSQL (Prisma)
POSTGRES_USER=tms
POSTGRES_PASSWORD=tms_pass
POSTGRES_DB=tms
# When running API on host against docker postgres use localhost:5433 (compose maps 5433->5432);
# inside docker the api service overrides this to host "postgres".
DATABASE_URL=postgresql://tms:tms_pass@localhost:5433/tms?schema=public

# Redis
# host: localhost when API on host; "redis" inside docker
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# Worker: how often (seconds) Redis counters are flushed to TrafficDaily
TRAFFIC_SYNC_INTERVAL_SEC=60
# Link config cache TTL in Redis (seconds)
LINK_CACHE_TTL_SEC=30

# ───────── Web ─────────
# Base URL the SPA uses to reach the API
VITE_API_BASE_URL=http://localhost:3000/api/v1
